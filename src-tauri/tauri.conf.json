{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tidy-app",
  "version": "1.0.0",
  "identifier": "com.tidy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "targets": [
      "app"
    ],
    "category": "public.app-category.productivity",
    "shortDescription": "File triage desktop tool",
    "longDescription": "Tidy-app lets you scan folders, preview files, and quickly move or delete clutter."
  },
  "app": {
    "windows": [
      {
        "title": "Tidy-app",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: media: data: blob:; media-src 'self' media: data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  }
}
